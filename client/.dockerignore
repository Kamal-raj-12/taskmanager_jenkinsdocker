# Dependencies — re-installed during docker build
node_modules/

# Previous build output — rebuilt fresh in the container
build/

# Environment files — should never be baked into an image
.env
.env.*

# Logs & debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor artefacts
.DS_Store
.vscode/
.idea/

# Git
.git/
.gitignore
