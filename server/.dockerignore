# Dependencies — re-installed during docker build
node_modules/

# Environment files — injected at runtime via docker run -e or Docker secrets
.env
.env.*

# Upload directory — should be on a mounted volume, not inside the image
uploads/

# Logs & debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor artefacts
.DS_Store
.vscode/
.idea/

# Git
.git/
.gitignore
